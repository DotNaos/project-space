{
  "name": "project-space",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop-first workspace management foundation for project-centered workflows.",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "bin": {
    "project": "./bin/project"
  },
  "scripts": {
    "dev": "VITE_PROJECT_SPACE_API_BASE_URL=http://127.0.0.1:45873 vite --host 127.0.0.1",
    "dev:electron": "vite --mode electron --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:connector:macos-arm64": "bun build --compile --target=bun-darwin-arm64 server/web-server.ts --outfile dist/project-space-connector",
    "build:electron": "tsc -b && vite build --mode electron",
    "check": "tsc -b",
    "check:cli": "go test ./...",
    "connector:serve": "tailscale serve --bg --yes 4173",
    "connector:status": "tailscale serve status --json",
    "connector:start": "bun server/web-server.ts",
    "dev:connector": "VITE_PROJECT_SPACE_API_BASE_URL=http://127.0.0.1:45873 vite --host 127.0.0.1",
    "preview": "vite preview",
    "start": "bun server/web-server.ts"
  },
  "dependencies": {
    "@dotnaos/react-ui": "^0.0.2",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.2.0",
    "react-devtools-core": "^7.0.1",
    "react-devtools-electron": "^4.7.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
