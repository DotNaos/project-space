#!/usr/bin/env bash
set -euo pipefail

PROJECT_SPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_SPACE_BIN="${TMPDIR:-/tmp}/project-space-project-cli"
(cd "$PROJECT_SPACE_ROOT" && go build -o "$PROJECT_SPACE_BIN" ./cmd/project)
export PROJECT_SPACE_TEMPLATE_ROOT="$PROJECT_SPACE_ROOT/templates/project-template"
exec "$PROJECT_SPACE_BIN" "$@"
