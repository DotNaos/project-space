# config: local HTTP host for the Go runtime.
PROJECT_SPACE_HOST=127.0.0.1

# config: local HTTP port for the Go runtime.
PROJECT_SPACE_PORT=4173

# config: optional hosted private platform API base URL.
PROJECT_SPACE_PRIVATE_VPS_BASE_URL=

# config: optional connector origin shown in machine status.
PROJECT_SPACE_CONNECTOR_ORIGIN=

# secret: optional GitHub token for private release/Homebrew access.
GITHUB_TOKEN=

# secret: optional Apple account for future notarized macOS releases.
APPLE_ID=

# secret: optional Apple team id for future notarized macOS releases.
APPLE_TEAM_ID=

# secret: optional app-specific password for future notarized macOS releases.
APPLE_APP_SPECIFIC_PASSWORD=

# secret: optional base64 encoded Apple signing certificate.
APPLE_CERTIFICATE_P12_BASE64=

# secret: optional Apple certificate password.
APPLE_CERTIFICATE_PASSWORD=

# secret: optional Apple signing identity.
APPLE_SIGNING_IDENTITY=
